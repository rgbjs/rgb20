{
  "name": "rgb20",
  "version": "0.0.1",
  "description": "RGB20 contract creation library with StrictEncode and BAID64 integration",
  "type": "module",
  "main": "index.js",
  "bin": {
    "rgb20": "./cli.js"
  },
  "exports": {
    ".": {
      "import": "./index.js",
      "require": "./index.cjs"
    }
  },
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/jest --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage",
    "build:cjs": "node build-cjs.js",
    "lint": "eslint *.js test/*.js",
    "docs": "jsdoc -d docs *.js",
    "prepublishOnly": "npm run test && npm run build:cjs"
  },
  "keywords": [
    "rgb20",
    "rgb",
    "bitcoin",
    "smart-contracts",
    "strictencode",
    "baid64",
    "token-contracts",
    "consensus-critical"
  ],
  "author": {
    "name": "RGB Community",
    "url": "https://rgb.tech"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/rgbjs/rgb20.git"
  },
  "bugs": {
    "url": "https://github.com/rgbjs/rgb20/issues"
  },
  "homepage": "https://github.com/rgbjs/rgb20#readme",
  "engines": {
    "node": ">=14.0.0"
  },
  "dependencies": {
    "strictencode": "file:../strictencode",
    "baid64": "file:../baid64"
  },
  "devDependencies": {
    "jest": "^29.5.0",
    "eslint": "^8.40.0",
    "jsdoc": "^4.0.2"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "collectCoverageFrom": [
      "*.js",
      "!build-cjs.js",
      "!docs/**"
    ]
  }
}